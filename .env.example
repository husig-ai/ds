# ============================================================
# Supabase Configuration
# ============================================================
# Get these from: Supabase Dashboard > Project Settings > API

# Your Supabase project URL
# Found in: Settings > API > Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anonymous public key
# Found in: Settings > API > Project API keys > anon/public
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Note: This is a static site. Put credentials directly in js/supabase-client.js
# The anon key is safe to expose as it only grants read access to public data
# and insert access to leads table (controlled by Row Level Security policies).

# ============================================================
# Site Branding & Configuration
# ============================================================
# Customize these for your real estate business.
# These values will replace {{CONFIG.xxx}} placeholders throughout the site.

# Agent name
VITE_AGENT_FIRST_NAME=Agent
VITE_AGENT_LAST_NAME=Name

# Company name
VITE_COMPANY_NAME=Realty

# Location
VITE_PRIMARY_LOCATION=City, State
VITE_SERVICE_AREAS=Local service area description

# Agent stats (displayed on home page)
VITE_YEARS_IN_MARKET=10
VITE_HOMES_CLOSED_COUNT=100+
VITE_CLIENT_RATING=5.0

# Note: For static sites, edit js/config.js directly to change these values.
# Or set window.appConfig in a script tag before loading the page.
#
# ⚠️  IMPORTANT: Never commit actual PII to version control.
# Keep .env with real information in .gitignore (already configured).
